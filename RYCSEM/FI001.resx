  <data name="SqlSelectCommand1.CommandText" xml:space="preserve">
    <value>SELECT        articulos.cod_art, articulos.descripcion, articulos.costo, articulos.precio, articulos.observaciones, articulos.status, articulos.imagen, articulos.usuario, articulos.nombre_imagen, articulos.porc_ganancia, 
                         dbo.ObtenerValor(articulos.cod_art, '01') AS existencia, articulos.modelo, articulos.tipo, ISNULL(modelos.nombre, '') AS nombre_modelo, ISNULL(tipos.nombre, '') AS nombre_tipo
FROM            articulos WITH (nolock) LEFT OUTER JOIN
                         modelos WITH (nolock) ON modelos.modelo = articulos.modelo LEFT OUTER JOIN
                         tipos WITH (nolock) ON tipos.tipo = articulos.tipo</value>
  </data>
