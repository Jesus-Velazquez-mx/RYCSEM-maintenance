  <data name="SqlUpdateCommand1.CommandText" xml:space="preserve">
    <value>UPDATE       articulos
SET                cod_art = @cod_art, descripcion = @descripcion, costo = @costo, precio = @precio, observaciones = @observaciones, status = @status, imagen = @imagen, nombre_imagen = @nombre_imagen, usuario = @usuario, 
                         porc_ganancia = @porc_ganancia, cod_prv = '', razon_social = '', modelo = @modelo, tipo = @tipo
WHERE        (cod_art = @Original_cod_art)</value>
