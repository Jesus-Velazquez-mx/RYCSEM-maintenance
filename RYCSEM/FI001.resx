  <data name="SqlUpdateCommand1.CommandText" xml:space="preserve">
    <value>UPDATE [articulos] SET [cod_art] = @cod_art, [descripcion] = @descripcion, [costo] = @costo, [precio] = @precio, [observaciones] = @observaciones, [status] = @status, [imagen] = @imagen, [usuario] = @usuario, [nombre_imagen] = @nombre_imagen, [porc_ganancia] = @porc_ganancia, [modelo] = @modelo, [tipo] = @tipo WHERE (([cod_art] = @Original_cod_art) AND ((@IsNull_descripcion = 1 AND [descripcion] IS NULL) OR ([descripcion] = @Original_descripcion)) AND ((@IsNull_costo = 1 AND [costo] IS NULL) OR ([costo] = @Original_costo)) AND ((@IsNull_precio = 1 AND [precio] IS NULL) OR ([precio] = @Original_precio)) AND ((@IsNull_observaciones = 1 AND [observaciones] IS NULL) OR ([observaciones] = @Original_observaciones)) AND ((@IsNull_status = 1 AND [status] IS NULL) OR ([status] = @Original_status)) AND ((@IsNull_usuario = 1 AND [usuario] IS NULL) OR ([usuario] = @Original_usuario)) AND ((@IsNull_nombre_imagen = 1 AND [nombre_imagen] IS NULL) OR ([nombre_imagen] = @Original_nombre_imagen)) AND ((@IsNull_porc_ganancia = 1 AND [porc_ganancia] IS NULL) OR ([porc_ganancia] = @Original_porc_ganancia)) AND ((@IsNull_modelo = 1 AND [modelo] IS NULL) OR ([modelo] = @Original_modelo)) AND ((@IsNull_tipo = 1 AND [tipo] IS NULL) OR ([tipo] = @Original_tipo)));
SELECT articulos.cod_art, articulos.descripcion, articulos.costo, articulos.precio, articulos.observaciones, articulos.status, articulos.imagen, articulos.usuario, articulos.nombre_imagen, articulos.porc_ganancia, dbo.ObtenerValor(articulos.cod_art, '01') AS existencia, articulos.modelo, articulos.tipo, ISNULL(modelos.nombre, '') AS nombre_modelo, ISNULL(tipos.nombre, '') AS nombre_tipo FROM articulos WITH (nolock) LEFT OUTER JOIN modelos WITH (nolock) ON modelos.modelo = articulos.modelo LEFT OUTER JOIN tipos WITH (nolock) ON tipos.tipo = articulos.tipo WHERE (articulos.cod_art = @cod_art)</value>
  </data>
