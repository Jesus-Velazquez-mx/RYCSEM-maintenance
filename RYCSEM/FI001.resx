  <data name="SqlInsertCommand1.CommandText" xml:space="preserve">
    <value>INSERT INTO articulos
                         (cod_art, descripcion, costo, precio, observaciones, status, imagen, nombre_imagen, usuario, porc_ganancia, cod_prv, razon_social, modelo, tipo)
VALUES        (@cod_art,@descripcion,@costo,@precio,@observaciones,@status,@imagen,@nombre_imagen,@usuario,@porc_ganancia, '', '',@modelo,@tipo)</value>
  </data>
