  <data name="SqlSelectCommand1.CommandText" xml:space="preserve">
    <value>SELECT        folio, transaccion, fecha, cod_cte, domicilio_entrega, cond_pago, plazo, porc_descuento, importe_descuento, importe, iva, ieps, total, saldo, abonos, forma_pago, venta_publico, razon_social
