  <data name="SqlUpdateCommand1.CommandText" xml:space="preserve">
    <value>UPDATE       notas_venta
SET                fecha = @fecha, cod_cte = @cod_cte, domicilio_entrega = @domicilio_entrega, cond_pago = @cond_pago, plazo = @plazo, porc_descuento = @porc_descuento, importe_descuento = @importe_descuento, importe = @importe, 
                         iva = @iva, ieps = @ieps, saldo = @saldo, abonos = @abonos, forma_pago = @forma_pago, venta_publico = @venta_publico, razon_social = @razon_social
WHERE        (folio = @Original_folio)</value>
  </data>
