  <data name="SqlSelectCommand2.CommandText" xml:space="preserve">
    <value>SELECT        notas_venta_detalle.folio, notas_venta_detalle.transaccion, notas_venta_detalle.cantidad, notas_venta_detalle.cod_art, notas_venta_detalle.unidad, notas_venta_detalle.importe, notas_venta_detalle.iva, 
                         notas_venta_detalle.ieps, notas_venta_detalle.porc_descuento, notas_venta_detalle.importe_descuento, notas_venta_detalle.total, articulos.descripcion, articulos.precio, articulos.imagen, articulos.nombre_imagen
FROM            notas_venta_detalle INNER JOIN
                         articulos ON articulos.cod_art = notas_venta_detalle.cod_art
WHERE        (notas_venta_detalle.folio = @folio)</value>
  </data>
