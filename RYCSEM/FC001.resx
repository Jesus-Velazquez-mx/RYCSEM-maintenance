  <data name="SqlInsertCommand.CommandText" xml:space="preserve">
    <value>INSERT INTO [clientes] ([cod_cte], [razon_social], [nombre], [rfc], [ap_paterno], [ap_materno], [telefono], [extension], [telefono2], [celular], [calle], [calle_num], [calle_entre1], [calle_entre2], [colonia], [cod_postal], [status]) VALUES (@cod_cte, @razon_social, @nombre, @rfc, @ap_paterno, @ap_materno, @telefono, @extension, @telefono2, @celular, @calle, @calle_num, @calle_entre1, @calle_entre2, @colonia, @cod_postal, @status);
SELECT cod_cte, razon_social, nombre, rfc, ap_paterno, ap_materno, telefono, extension, telefono2, celular, calle, calle_num, calle_entre1, calle_entre2, colonia, cod_postal, status, dbo.direccionCompleta(cod_cte, 'C') AS direccionCompleta, dbo.nombreCompleto(cod_cte, 'C') AS nombreCompleto, ISNULL(usuario, '') AS usuario FROM clientes WITH (NOLOCK) WHERE (cod_cte = @cod_cte)</value>
  </data>
