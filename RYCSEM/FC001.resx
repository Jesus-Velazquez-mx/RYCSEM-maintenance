  <data name="SqlUpdateCommand.CommandText" xml:space="preserve">
    <value>UPDATE [clientes] SET [cod_cte] = @cod_cte, [razon_social] = @razon_social, [nombre] = @nombre, [rfc] = @rfc, [ap_paterno] = @ap_paterno, [ap_materno] = @ap_materno, [telefono] = @telefono, [extension] = @extension, [telefono2] = @telefono2, [celular] = @celular, [calle] = @calle, [calle_num] = @calle_num, [calle_entre1] = @calle_entre1, [calle_entre2] = @calle_entre2, [colonia] = @colonia, [cod_postal] = @cod_postal, [status] = @status WHERE (([cod_cte] = @Original_cod_cte) AND ((@IsNull_razon_social = 1 AND [razon_social] IS NULL) OR ([razon_social] = @Original_razon_social)) AND ((@IsNull_nombre = 1 AND [nombre] IS NULL) OR ([nombre] = @Original_nombre)) AND ((@IsNull_rfc = 1 AND [rfc] IS NULL) OR ([rfc] = @Original_rfc)) AND ((@IsNull_ap_paterno = 1 AND [ap_paterno] IS NULL) OR ([ap_paterno] = @Original_ap_paterno)) AND ((@IsNull_ap_materno = 1 AND [ap_materno] IS NULL) OR ([ap_materno] = @Original_ap_materno)) AND ((@IsNull_telefono = 1 AND [telefono] IS NULL) OR ([telefono] = @Original_telefono)) AND ((@IsNull_extension = 1 AND [extension] IS NULL) OR ([extension] = @Original_extension)) AND ((@IsNull_telefono2 = 1 AND [telefono2] IS NULL) OR ([telefono2] = @Original_telefono2)) AND ((@IsNull_celular = 1 AND [celular] IS NULL) OR ([celular] = @Original_celular)) AND ((@IsNull_calle = 1 AND [calle] IS NULL) OR ([calle] = @Original_calle)) AND ((@IsNull_calle_num = 1 AND [calle_num] IS NULL) OR ([calle_num] = @Original_calle_num)) AND ((@IsNull_calle_entre1 = 1 AND [calle_entre1] IS NULL) OR ([calle_entre1] = @Original_calle_entre1)) AND ((@IsNull_calle_entre2 = 1 AND [calle_entre2] IS NULL) OR ([calle_entre2] = @Original_calle_entre2)) AND ((@IsNull_colonia = 1 AND [colonia] IS NULL) OR ([colonia] = @Original_colonia)) AND ((@IsNull_cod_postal = 1 AND [cod_postal] IS NULL) OR ([cod_postal] = @Original_cod_postal)) AND ((@IsNull_status = 1 AND [status] IS NULL) OR ([status] = @Original_status)));
