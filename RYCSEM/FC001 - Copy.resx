  <data name="SqlInsertCommand.CommandText" xml:space="preserve">
    <value>INSERT INTO [clientes] ([cod_cte], [razon_social], [nombre], [rfc], [ap_paterno], [ap_materno], [telefono], [extension], [telefono2], [celular], [calle], [calle_num], [calle_entre1], [calle_entre2], [colonia], [cod_postal], [status]) VALUES (@cod_cte, @razon_social, @nombre, @rfc, @ap_paterno, @ap_materno, @telefono, @extension, @telefono2, @celular, @calle, @calle_num, @calle_entre1, @calle_entre2, @colonia, @cod_postal, @status)</value>
  </data>
