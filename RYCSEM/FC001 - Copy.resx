  </metadata>
  <data name="SqlUpdateCommand.CommandText" xml:space="preserve">
    <value>UPDATE [clientes] SET [cod_cte] = @cod_cte, [razon_social] = @razon_social, [nombre] = @nombre, [rfc] = @rfc, [ap_paterno] = @ap_paterno, [ap_materno] = @ap_materno, [telefono] = @telefono, [extension] = @extension, [telefono2] = @telefono2, [celular] = @celular, [calle] = @calle, [calle_num] = @calle_num, [calle_entre1] = @calle_entre1, [calle_entre2] = @calle_entre2, [colonia] = @colonia, [cod_postal] = @cod_postal, [status] = @status WHERE (([cod_cte] = @Original_cod_cte))</value>
  </data>
