  <data name="SqlSelectCommand4.CommandText" xml:space="preserve">
    <value>SELECT        notas_venta_detalle.id, notas_venta_detalle.folio, notas_venta_detalle.transaccion, notas_venta_detalle.cantidad, notas_venta_detalle.cod_art, notas_venta_detalle.unidad, notas_venta_detalle.importe, 
                         notas_venta_detalle.iva, notas_venta_detalle.ieps, notas_venta_detalle.porc_descuento, notas_venta_detalle.importe_descuento, notas_venta_detalle.total, A.descripcion
FROM            notas_venta_detalle WITH (nolock) INNER JOIN
                         articulos AS A WITH (nolock) ON A.cod_art = notas_venta_detalle.cod_art
WHERE        (notas_venta_detalle.folio = @folio) AND (notas_venta_detalle.transaccion = @transaccion)</value>
  </data>
