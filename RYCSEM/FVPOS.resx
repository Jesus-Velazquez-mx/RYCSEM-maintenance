  <data name="sqlGuardaNotaVenta.CommandText" xml:space="preserve">
    <value>INSERT INTO notas_venta
                         (folio, transaccion, fecha, cod_cte, domicilio_entrega, cond_pago, plazo, porc_descuento, importe_descuento, importe, iva, ieps, saldo, abonos, forma_pago, venta_publico, razon_social, total, domicilio_cliente, status, 
                         entregado, enganche, porc_enganche, notas)
VALUES        (@folio,@transaccion,@fecha,@cod_cte,@domicilio_entrega,@cond_pago,@plazo,@porc_descuento,@importe_descuento,@importe,@iva,@ieps,@saldo,@abonos,@forma_pago,@venta_publico,@razon_social,@total,@domicilio_cliente,@status,@entregado,@enganche,@porc_enganche,@notas)</value>
  </data>
