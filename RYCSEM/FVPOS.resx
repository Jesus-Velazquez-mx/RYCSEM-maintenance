  <data name="sqlGuardaNotaDetalle.CommandText" xml:space="preserve">
    <value>INSERT INTO notas_venta_detalle
                         (folio, transaccion, cantidad, cod_art, unidad, importe, iva, ieps, porc_descuento, importe_descuento, total)
