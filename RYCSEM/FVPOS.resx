  <data name="SqlSelectCommand3.CommandText" xml:space="preserve">
    <value>SELECT        folio, transaccion, fecha, cod_cte, domicilio_entrega, cond_pago, plazo, porc_descuento, importe_descuento, importe, iva, ieps, saldo, abonos, forma_pago, venta_publico, razon_social, total, domicilio_cliente, status, 
                         entregado, enganche, porc_enganche, notas, dbo.nombreCompleto(folio, 'AT') AS atendio, dbo.ObtenerValor(folio, 'PE') AS efectivo, dbo.ObtenerValor(folio, 'PT') AS tarjeta
FROM            notas_venta WITH (nolock)
WHERE        (folio = @folio) AND (transaccion = @transaccion)</value>
  </data>
