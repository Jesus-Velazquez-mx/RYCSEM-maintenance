  <data name="SqlUpdateCommand1.CommandText" xml:space="preserve">
    <value>UPDATE       articulos
SET                cod_art = @cod_art, descripcion = @descripcion, costo = @costo, precio = @precio, observaciones = @observaciones, status = @status, imagen = @imagen, usuario = @usuario, nombre_imagen = @nombre_imagen, 
                         linea_articulo = @linea_articulo, porc_ganancia = @porc_ganancia
WHERE        (cod_art = @Original_cod_art)</value>
  </data>
