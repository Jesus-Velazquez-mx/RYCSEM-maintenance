  <data name="SqlSelectCommand1.CommandText" xml:space="preserve">
    <value>SELECT        cod_art, descripcion, costo, costo * (1 + porc_ganancia / 100) AS precio, observaciones, status, imagen, usuario, nombre_imagen, linea_articulo, porc_ganancia
FROM            articulos WITH (nolock)</value>
  </data>
