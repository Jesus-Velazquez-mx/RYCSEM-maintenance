  <data name="SqlInsertCommand1.CommandText" xml:space="preserve">
    <value>INSERT INTO articulos
                         (cod_art, descripcion, costo, precio, observaciones, status, imagen, usuario, nombre_imagen, linea_articulo, porc_ganancia)
VALUES        (@cod_art,@descripcion,@costo,@precio,@observaciones,@status,@imagen,@usuario,@nombre_imagen,@linea_articulo,@porc_ganancia)</value>
  </data>
